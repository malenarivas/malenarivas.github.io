body {
	font-family: 'Exo 2', sans-serif;
	color: #FFFFFF;
	background: #000000;
	font-size: 11pt;
	margin: 0px;
	overflow-x: hidden;
	padding-bottom: 80px;
}

.pageBody {
	display: flex;
	width: 1124px;
	margin-left: auto;
	margin-right: auto;
}

.bodyMain {
	display:inline-block;
	width: 770px;
	margin-top: 20px;
	
}

.bodySidebar {
	display: inline-block;
	width: 300px;
	margin-top: 20px;
	margin-left: 20px;
}

.pageHeader {
	display:inline-block;
	background-position: top;
	background-size: auto;
	background-repeat: repeat;
	background-color: #151b26;
	height: 46px;
	width: 100%;
}
h2 {
	text-transform: uppercase;
}

b {
	color: #BDBD8C;
	letter-spacing: -4px;
}

b:hover {
  cursor: default;
}

.pageHeaderText {
	padding-left: .75rem !important;
	padding-right: .75rem !important;
}

.cardHeader {
	margin: 0px;
	padding: 10px;
	font-size: 12pt;
	text-align: center;
	color: #BDBD8C;
	border-radius: 2px 2px 0px 0px;
	background-color: #262b37;
	font-style: italic;
	font-weight: 900;
}
.card {
	background-color: #151b26;
}

.cardContent {
	padding: 20px;
}

.sidebarCard {
	background-color: #151b26;
}

.sidebarCardContent {
	padding: 20px;
}

h2 {
	flex: 1;
}

A:link {
  text-decoration: none;
  color: #BDBD8C;
}

A:hover {
  text-decoration: none;
  color: #FFFFFF !important;
}

A:visited {
  text-decoration: none;
  color: #BDBD8C;
}

.tab {
	font-family: 'Exo 2', sans-serif;
	border: 0px;
	padding: 6px 10px;
	background-color: #1d212b;
	color: #575757;
	cursor: pointer;
	font-weight: bold;
	letter-spacing: .5px;
}

.tab.active {
  background-color: #262b37;
  color: #f1f1f1;
}

.tab:hover {
  color: white;
}

.zoom {
	animation: zoom 2s ease infinite;
}

@keyframes zoom {
  0% {
    transform: scale(1, 1);
  }
  50% {
    transform: scale(1.2, 1.2);
  }
  100% {
    transform: scale(1, 1);
  }
}

@media screen and (max-width: 800px) {
	.leftcolumn, .rightcolumn {	 
	width: 100%;
	padding: 0;
	}
}